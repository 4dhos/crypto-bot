# ── MODE ──────────────────────────────────────────────────────────────────────
# PAPER → Fully simulated paper trading. NO API keys needed. US-friendly.
#         Uses live MEXC public market data. Start here.
# LIVE  → Real money on MEXC Perpetuals. Requires MEXC API keys below.
TRADING_MODE=PAPER

# ── PAPER MODE SETTINGS ───────────────────────────────────────────────────────
# No API keys required in PAPER mode.
# Market data is pulled from MEXC public endpoints (no auth, no geo-block).
# Adjust starting balance in config.py → PAPER_STARTING_BALANCE (default: $100)

# ── MEXC (LIVE mode only) ─────────────────────────────────────────────────────
# Only needed when TRADING_MODE=LIVE
MEXC_API_KEY=your_mexc_api_key_here
MEXC_API_SECRET=your_mexc_api_secret_here

# ── TELEGRAM (optional, both modes) ──────────────────────────────────────────
# Leave blank to disable Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
